### APP ###
APP_PORT=3000
METRICS_PORT=3001

### API ###
API_INSTANCES=1

### DATABASE ###
DATABASE_URL=postgresql://postgres:remnawave@remnawave-postgres:5432/remnawave

### REDIS ###
REDIS_SOCKET=/var/run/valkey/valkey.sock

### JWT ###
JWT_AUTH_SECRET=change_me
JWT_API_TOKENS_SECRET=change_me

### DOMAINS ###
FRONT_END_DOMAIN=*
SUB_PUBLIC_DOMAIN=remnawave.${BASE_DOMAIN:=libre.pod}/api/sub
PANEL_DOMAIN=remnawave.${BASE_DOMAIN:=libre.pod}

### TELEGRAM NOTIFICATIONS ###
IS_TELEGRAM_NOTIFICATIONS_ENABLED=false

### DOCS ###
IS_DOCS_ENABLED=false

### PROMETHEUS ###
METRICS_USER=admin
METRICS_PASS=change_me

### WEBHOOK ###
WEBHOOK_ENABLED=false
