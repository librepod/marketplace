# WG-Easy Configuration (generic defaults)
#
# Environment-specific values are injected at deploy time by Flux
# postBuild.substitute (see metadata.yaml). INIT_HOST resolves from
# ${FRP_SERVER_ADDR}, the public FRP relay address WireGuard clients dial.

# WireGuard endpoint host baked into client configs (public FRP server)
INIT_HOST=${FRP_SERVER_ADDR}
TZ=${TZ:-UTC}

# v15 Unattended Setup (only used on first start)
INIT_ENABLED=true
INIT_USERNAME=admin
INIT_PORT=51820
INIT_DNS=10.43.0.10
INIT_IPV4_CIDR=10.6.0.0/24
INIT_IPV6_CIDR=

# v15 Optional Configuration
INSECURE=true
DISABLE_IPV6=true
