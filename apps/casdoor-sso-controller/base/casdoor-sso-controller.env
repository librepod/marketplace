# Non-secret controller configuration. Consumed by the configMapGenerator in
# kustomization.yaml and loaded into BOTH containers (bootstrap init + manager)
# via envFrom. Flux substitutes ${BASE_DOMAIN} at deploy time via postBuild
# (see infrastructure/system-apps/casdoor-sso-controller.yaml).

# Cluster base domain — the manager uses it to build Casdoor issuer/redirect URLs.
BASE_DOMAIN=${BASE_DOMAIN}

# In-cluster Casdoor admin API (Service DNS).
CASDOOR_BASE_URL=http://casdoor.casdoor.svc.cluster.local:8000

# Casdoor organization the controller provisions SSOClient applications into.
CASDOOR_ORG=librepod

# Built-in admin password. The bootstrap init container uses it ONLY on first
# boot to mint the controller's own access key (which is independent of this
# password). Left at the Casdoor default "123" (in-cluster only); onboarding
# replaces it later. Real access credentials come from the bootstrap-generated
# Secret via secretKeyRef in the Deployment, NOT from here.
CASDOOR_ADMIN_PASSWORD=123

# Bootstrap-only: where the minted credential is persisted on the creds PVC,
# and which namespace the derived Secret is written to.
CREDS_FILE=/creds/credentials.json
SECRET_NAMESPACE=casdoor-sso-controller
