# Connection details shared by the immich-server (Helm chart) and the bundled
# postgres Deployment. DB_PASSWORD / POSTGRES_PASSWORD both resolve to the same
# marketplace-generated value via Flux postBuild.substitute (loaded from the
# immich-config Secret). Plain-text in a ConfigMap is intentional here: it is the
# documented workaround for Flux being unable to substitute vars inside a
# secretGenerator's base64 output.

# --- immich-server → database ---
DB_HOSTNAME=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_VECTOR_EXTENSION=vectorchord
DB_PASSWORD=${DB_PASSWORD}

# --- postgres bootstrap (POSTGRES_* are read by the postgres image on first init) ---
POSTGRES_USER=postgres
POSTGRES_DB=immich
POSTGRES_PASSWORD=${DB_PASSWORD}
POSTGRES_INITDB_ARGS=--data-checksums
