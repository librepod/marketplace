{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@librepod/shared": ["../shared/src/types.ts"]
    },
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "strict": true
  },
  "include": ["src/**/*"]
}
